generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SELLER
  SERVICE
  ADMIN
}

enum SellerType {
  PRIVATE
  DEALER
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  seller Seller?
  bids   Bid[]
}

model Seller {
  id        String     @id @default(cuid())
  userId    String     @unique
  type      SellerType
  name      String
  city      String
  rating    Float
  verified  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]
}

model Listing {
  id          String        @id @default(cuid())
  title       String
  description String
  price       Decimal       @db.Decimal(12, 2)
  status      ListingStatus
  sellerId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seller   Seller    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  vehicles Vehicle[]
  parts    Part[]
  services Service[]
  images   Image[]
  auctions Auction[]
}

model Vehicle {
  id           String  @id @default(cuid())
  listingId    String
  brand        String
  model        String
  year         Int
  mileage      Int
  fuel         String
  transmission String
  engineVolume Float
  power        Int

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Part {
  id        String @id @default(cuid())
  listingId String
  name      String
  category  String
  brand     String
  model     String
  condition String
  oemCode   String
  stock     Int

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Service {
  id              String   @id @default(cuid())
  listingId       String
  name            String
  categories      String[]
  supportedBrands String[]
  city            String
  rating          Float

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Image {
  id        String @id @default(cuid())
  listingId String
  url       String
  position  Int

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Auction {
  id           String   @id @default(cuid())
  listingId    String
  startPrice   Decimal  @db.Decimal(12, 2)
  currentPrice Decimal  @db.Decimal(12, 2)
  startTime    DateTime
  endTime      DateTime
  status       String

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bids    Bid[]
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
